# AI Law Firm — Dubai-DIFC · config.toml
# Generated by setup.sh. Customize as needed.

[jurisdiction]
country = "Dubai-DIFC"
citation_format = "DIFC Courts neutral citations"     # e.g. "DIFC [2025] CFI 001"
court_hierarchy = "../dubai-difc/_court_hierarchy.json" # path to a JSON map of courts (dual-system: DIFC + mainland)
bar_rules = "../dubai-difc/_bar_rules.md"              # path to bar-rules markdown (DIFC / DFSA)
timezone = "Asia/Dubai"

[paths]
statute_corpus = "../dubai-difc/_statute_corpus/"
drafting_corpus = "../dubai-difc/_drafting_data/"
audit_log_dir = "~/.ailawfirm_dubai_difc/audit_logs/"
matter_root = "~/.ailawfirm_dubai_difc/matters/"

[llm]
provider = "claude"                                     # v0.1 only supports claude
# In v0.3+: "openai" · "gemini_paid" · "ollama" · "byom"
